# Build-time secrets read by `crates/core/build.rs` and baked into the
# firmware's default `WifiConfig`. Copy to `.env` (which is gitignored)
# and fill in. Only `SSID` and `PASSWORD` are forwarded to the compiler;
# everything else is ignored.
#
# Used by:
#   - WifiConfig::default() — first-boot WiFi credentials. Leave both
#     empty (or remove the file) to make the device boot in AP fallback
#     and configure WiFi via the SPA captive portal instead.
#
# These values land in the binary as plaintext via `option_env!()`. Keep
# `.env` out of git (it already is via .gitignore) and rotate the
# password if you suspect leakage.

SSID=demo-cncf-madrid
PASSWORD=demodemo1234
