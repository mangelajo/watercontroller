# Match the ESPHome reference: 80 MHz CPU, size-optimized.
CONFIG_ESP_DEFAULT_CPU_FREQ_MHZ_80=y
CONFIG_ESP_DEFAULT_CPU_FREQ_MHZ=80
CONFIG_COMPILER_OPTIMIZATION_SIZE=y

# Logging — keep verbose available; runtime level is set in code.
CONFIG_LOG_DEFAULT_LEVEL_INFO=y
CONFIG_LOG_DEFAULT_LEVEL=3
CONFIG_LOG_MAXIMUM_LEVEL_VERBOSE=y
CONFIG_LOG_MAXIMUM_LEVEL=5

# Watchdog: be lenient during early bring-up; tighten later.
CONFIG_ESP_TASK_WDT_TIMEOUT_S=30

# Main task stack: ESP-IDF default is 3584 B which is tight once we layer
# WiFi supervisor + HTTPD config + MQTT cert plumbing on top of the Rust
# panic handler. Bump to 8 KB.
CONFIG_ESP_MAIN_TASK_STACK_SIZE=8192

# Custom partition table for OTA + NVS + SPA assets. Absolute path in the
# container is required when sdkconfig.defaults is provided via env var —
# CMake otherwise resolves the relative path against esp-idf-sys's synthetic
# project dir, where partitions.csv doesn't live.
CONFIG_PARTITION_TABLE_CUSTOM=y
CONFIG_PARTITION_TABLE_CUSTOM_FILENAME="/project/crates/firmware/partitions.csv"
CONFIG_PARTITION_TABLE_FILENAME="/project/crates/firmware/partitions.csv"

# 4 MB flash (matches the dev-kit ESP32-WROOM modules).
CONFIG_ESPTOOLPY_FLASHSIZE_2MB=n
CONFIG_ESPTOOLPY_FLASHSIZE_4MB=y
CONFIG_ESPTOOLPY_FLASHSIZE="4MB"

# OTA — enable rollback on boot failure.
CONFIG_BOOTLOADER_APP_ROLLBACK_ENABLE=y

# WiFi — use ESP-IDF defaults; we'll tune buffer sizes later if needed.
CONFIG_ESP_WIFI_ENABLED=y

# FreeRTOS tick rate — 1ms ticks for finer timing in valve sequencer.
CONFIG_FREERTOS_HZ=1000

# Open-cores ETH driver: only used under `--features qemu` to attach lwIP to
# QEMU's open_eth virtual NIC. Adds ~few KB on real hardware where it goes
# unused; cheap insurance for a ground-truth simulator.
CONFIG_ETH_USE_OPENETH=y

# WebSocket support in the ESP-IDF HTTP server (used for /ws/logs).
CONFIG_HTTPD_WS_SUPPORT=y

# mDNS responder so doremorwater.local resolves on the LAN.
CONFIG_MDNS_MAX_INTERFACES=2

# HTTPS server. The firmware spawns *two* EspHttpServer instances when a
# cert + key are configured: one plain on :80, one TLS on :443. With no cert
# the device falls back to HTTP-only on :80 (esp_https_server is still linked
# in but starts in HTTPD_SSL_TRANSPORT_INSECURE mode).
#
# Note: esp_https_server's HTTP-only fallback null-derefs under QEMU, so
# `--features qemu` builds may not boot. Real hardware works.
CONFIG_ESP_HTTPS_SERVER_ENABLE=y

# LWIP socket pool. Default is 10. Two HTTPD servers each bring (listening
# + control + N sessions) sockets — easy to overshoot 10 and start hitting
# `accept (23)` (ENFILE) errors. 16 leaves headroom for telnet (:23), the
# WebSocket fanout, and a couple browser tabs without hitting the cap.
CONFIG_LWIP_MAX_SOCKETS=16

# HTTPD request header buffer. Default 512 is too tight for a real browser
# (Chromium sends User-Agent + Accept-* + multiple Sec-* + WS-upgrade easily
# overflowing 512 B), producing 431 Request Header Fields Too Large. 1024
# is roomy for browser navigation; the cost is ~512 B of heap per active
# connection, which we've now got room for.
CONFIG_HTTPD_MAX_REQ_HDR_LEN=1024

# mbedTLS memory tuning. Defaults are sized for an STA32 with 320 KB SRAM;
# on this device with two HTTPD servers running we have ~20 KB free heap at
# steady state and `mbedtls_ssl_setup` was returning ALLOC_FAILED on every
# handshake. Two changes:
#   1. DYNAMIC_BUFFER: only allocate the 16 KiB SSL read/write buffers when
#      a handshake is in flight, not pre-allocated per session. ~32 KB heap
#      saved at idle.
#   2. Lower the per-message buffer ceiling from 16 KiB → 4 KiB. The SPA's
#      JSON responses are <2 KiB; OTA upload is the only chunked path that
#      cares and it's HTTP-only.
CONFIG_MBEDTLS_DYNAMIC_BUFFER=y
CONFIG_MBEDTLS_SSL_IN_CONTENT_LEN=4096
CONFIG_MBEDTLS_SSL_OUT_CONTENT_LEN=4096

# Heap-saving knobs that DON'T drop user-visible features (WPA3, IPv6,
# Enterprise auth and OTA are all preserved).
#
# WiFi buffer pools — defaults are tuned for hundreds of KB/s of throughput.
# This device serves sub-kB JSON; halving the dynamic buffer counts frees
# ~30 KiB heap with no observable impact on latency or capability.
CONFIG_ESP_WIFI_DYNAMIC_RX_BUFFER_NUM=16
CONFIG_ESP_WIFI_DYNAMIC_TX_BUFFER_NUM=16
# TCP/IP recv mailbox depth: 32 is generous; 8 is ample for our traffic.
CONFIG_LWIP_TCPIP_RECVMBOX_SIZE=8

# Enable FreeRTOS trace + run-time stats so /api/diag can call
# uxTaskGetSystemState() and surface per-task stack high-water marks.
# Cost is small — a few bytes per task struct + a free-running run-time
# counter. Worth it for the visibility while we tune RAM.
CONFIG_FREERTOS_USE_TRACE_FACILITY=y
CONFIG_FREERTOS_USE_STATS_FORMATTING_FUNCTIONS=y
CONFIG_FREERTOS_GENERATE_RUN_TIME_STATS=y

# PSRAM probed once on this board (ESP32-D0WD, WROOM module): not present
# ("PSRAM ID read error: 0xffffffff"). Probing costs ~12 KiB of IRAM (the
# QPSRAM driver code is loaded even when init fails), which we can't spare
# on a heap-tight device. Re-enable for any new board that's WROVER-based:
#
#   CONFIG_SPIRAM=y
#   CONFIG_SPIRAM_USE_MEMMAP=y
#   CONFIG_SPIRAM_IGNORE_NOTFOUND=y
